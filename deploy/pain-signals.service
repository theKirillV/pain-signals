[Unit]
Description=Pain Signals - Reddit Problem Discovery
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/pain-signals
ExecStart=/opt/pain-signals/venv/bin/gunicorn --bind 127.0.0.1:5001 --workers 2 --timeout 120 app:app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
